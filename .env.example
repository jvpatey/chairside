# Copy to apps/mobile/.env

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# Pingram (NotificationAPI) — https://www.pingram.io/
# Pingram public key (pingram_pk_...) or environment client ID from dashboard
EXPO_PUBLIC_PINGRAM_CLIENT_ID=
# Optional: environment client ID if not using a pingram_pk_ public key
# EXPO_PUBLIC_PINGRAM_ENVIRONMENT_ID=your_pingram_client_id
# Optional overrides (defaults: api.ca.pingram.io / ws.ca.pingram.io)
# EXPO_PUBLIC_PINGRAM_API_HOST=api.ca.pingram.io
# EXPO_PUBLIC_PINGRAM_WS_HOST=ws.ca.pingram.io
