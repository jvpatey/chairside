# Chairside mobile — copy to .env for local development.
# EAS production/preview builds need the same EXPO_PUBLIC_* keys via `eas env:create`.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-token
EXPO_PUBLIC_PINGRAM_CLIENT_ID=your-pingram-environment-id-or-pingram_pk_...

# Optional
# EXPO_PUBLIC_PINGRAM_API_HOST=api.ca.pingram.io
# EXPO_PUBLIC_PINGRAM_WS_HOST=ws.ca.pingram.io
# EXPO_PUBLIC_PINGRAM_ENVIRONMENT_ID=
# EXPO_PUBLIC_WEB_BASE_URL=https://chairside.app
